# ============================================================
# 苍穹外卖系统 - 环境变量配置模板
# 复制本文件为 .env，填写实际值后运行 scripts\start-all.bat
# ============================================================

# ----------------------
# 数据库配置（必填）
# ----------------------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sky_take_out
DB_USERNAME=root
DB_PASSWORD=你的MySQL密码

# ----------------------
# Redis 配置（必填）
# ----------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码（无密码则留空）
REDIS_DATABASE=0

# ----------------------
# JWT 密钥（必填，必须 >= 32 字符）
# ----------------------
# 可使用以下命令生成随机密钥：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ADMIN_SECRET_KEY=change_me_to_a_random_string_at_least_32_chars_long
JWT_USER_SECRET_KEY=change_me_to_a_random_string_at_least_32_chars_long

# ----------------------
# 阿里云 OSS（可选，用于图片上传）
# ----------------------
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_BUCKET_NAME=
ALIYUN_ENDPOINT=

# ----------------------
# 微信小程序（可选，用于真实微信登录）
# ----------------------
WECHAT_APPID=
WECHAT_SECRET=

# ----------------------
# 应用配置（通常保持默认）
# ----------------------
SPRING_PROFILES_ACTIVE=dev
API_BASE_URL=http://localhost
MOCK_USER_LOGIN=true
MOCK_PAYMENT=true
