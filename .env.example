# ============================================================
# 苍穹外卖系统 - 环境变量配置模板
# Copy this file to .env at the repository root, fill placeholders,
# then run scripts\start-all.bat.
#
# IMPORTANT:
# - Do NOT commit a real .env. Only this template is tracked.
# - All values below are PLACEHOLDERS only. Replace before use.
# - tooling\.env.example is kept in sync with this file.
# ============================================================

# ----------------------
# Database (required)
# ----------------------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sky_take_out
DB_USERNAME=root
DB_PASSWORD=replace_with_your_mysql_password

# ----------------------
# Redis (required)
# ----------------------
# Leave REDIS_PASSWORD empty if your local Redis has no requirepass set.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ----------------------
# JWT secrets (required, MUST be >= 64 bytes / 64 ASCII chars)
# ----------------------
# JJWT 0.12.x with HS512 requires keys whose UTF-8 byte length is
# >= 64 bytes. Anything shorter will fail at startup with
# "WeakKeyException: The signing key's size is N bits which is not
# secure enough for the HS512 algorithm".
#
# Generate two independent secrets, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   openssl rand -base64 64 | tr -d '\n'
JWT_ADMIN_SECRET_KEY=replace_with_64_byte_random_admin_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_USER_SECRET_KEY=replace_with_64_byte_random_user_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional JWT TTL overrides (milliseconds). Defaults defined in
# application.yml are used when these are unset.
# JWT_ADMIN_TTL=7200000
# JWT_USER_TTL=7200000

# ----------------------
# Aliyun OSS (optional, image upload only)
# Leave empty to disable OSS upload paths.
# ----------------------
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_BUCKET_NAME=
ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ----------------------
# WeChat Mini Program (optional)
# Required only when you turn off MOCK_USER_LOGIN and use real wx.login.
# ----------------------
WECHAT_APPID=
WECHAT_SECRET=

# ----------------------
# WeChat Pay (optional, all placeholders)
# Required only when MOCK_PAYMENT=false.
# Private key and platform cert paths must be ABSOLUTE Windows paths
# (e.g. D:\sky-delivery\secrets\apiclient_key.pem) when used locally.
# ----------------------
WECHAT_MCHID=
WECHAT_MCH_SERIAL_NO=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY_FILE_PATH=
WECHAT_PAY_CERT_FILE_PATH=
WECHAT_NOTIFY_URL=
WECHAT_REFUND_NOTIFY_URL=

# ----------------------
# Application (usually leave defaults)
# ----------------------
SPRING_PROFILES_ACTIVE=dev
API_BASE_URL=http://localhost
MOCK_USER_LOGIN=true
MOCK_PAYMENT=true
