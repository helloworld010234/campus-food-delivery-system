# ============================================================
# Sky Take Out - tooling environment template
# Mirrors the root .env.example. Copy ONE of them to a real .env
# at the repository root; both contain the same variable names.
#
# All values are PLACEHOLDERS. Do not commit real secrets.
# ============================================================

# ----------------------
# Database (required)
# ----------------------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sky_take_out
DB_USERNAME=root
DB_PASSWORD=replace_with_your_mysql_password

# ----------------------
# Redis (required)
# ----------------------
# Leave REDIS_PASSWORD empty when local Redis has no requirepass.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ----------------------
# JWT secrets (required, MUST be >= 64 bytes / 64 ASCII chars)
# ----------------------
# JJWT 0.12.x with HS512 rejects keys shorter than 64 bytes.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#   openssl rand -base64 64 | tr -d '\n'
JWT_ADMIN_SECRET_KEY=replace_with_64_byte_random_admin_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_USER_SECRET_KEY=replace_with_64_byte_random_user_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional TTL overrides (ms). Defaults live in application.yml.
# JWT_ADMIN_TTL=7200000
# JWT_USER_TTL=7200000

# ----------------------
# Aliyun OSS (optional)
# ----------------------
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_BUCKET_NAME=
ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# ----------------------
# WeChat Mini Program (optional)
# ----------------------
WECHAT_APPID=
WECHAT_SECRET=

# ----------------------
# WeChat Pay (optional, all placeholders)
# ----------------------
WECHAT_MCHID=
WECHAT_MCH_SERIAL_NO=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY_FILE_PATH=
WECHAT_PAY_CERT_FILE_PATH=
WECHAT_NOTIFY_URL=
WECHAT_REFUND_NOTIFY_URL=

# ----------------------
# Application
# ----------------------
SPRING_PROFILES_ACTIVE=dev
API_BASE_URL=http://localhost
MOCK_USER_LOGIN=true
MOCK_PAYMENT=true
