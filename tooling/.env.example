# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sky_take_out
DB_USERNAME=sky
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DATABASE=0

# Aliyun OSS
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_BUCKET_NAME=your_bucket
ALIYUN_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# WeChat Mini Program
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# JWT (generate strong random keys, e.g. openssl rand -base64 32)
JWT_ADMIN_SECRET_KEY=change_me_to_strong_random_key
JWT_USER_SECRET_KEY=change_me_to_strong_random_key

# Application
SPRING_PROFILES_ACTIVE=dev
API_BASE_URL=http://localhost
MOCK_USER_LOGIN=true
MOCK_PAYMENT=true
