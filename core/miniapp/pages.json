{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "校园外卖"
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "提交订单",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/merchant/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "切换商家",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#2F5D50"
      }
    },
    {
      "path": "pages/details/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "订单详情",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/pay/index",
      "style": {
        "navigationBarTitleText": "支付订单",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/success/index",
      "style": {
        "navigationBarTitleText": "提交成功",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/nonet/index",
      "style": {
        "navigationBarTitleText": "网络异常"
      }
    },
    {
      "path": "pages/address/address",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "地址管理",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/remark/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "订单备注",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/my/my",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "个人中心",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#ffc200"
      }
    },
    {
      "path": "pages/addOrEditAddress/addOrEditAddress",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "新增收货地址",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    },
    {
      "path": "pages/historyOrder/historyOrder",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "历史订单",
        "enablePullDownRefresh": false,
        "navigationBarBackgroundColor": "#333333"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "校园外卖",
    "navigationBarBackgroundColor": "#E95F3C",
    "backgroundColor": "#F8F8F8"
  },
  "condition": {
    "current": 0,
    "list": [
      {
        "name": "历史订单",
        "path": "pages/index/index",
        "query": ""
      }
    ]
  }
}
