.pay-page.data-v-32f2f1fc {
  min-height: 100vh;
  background: #f6f2ea;
}
.pay-content.data-v-32f2f1fc {
  padding: 176rpx 24rpx 200rpx;
}
.pay-hero.data-v-32f2f1fc {
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #2f5d50 0%, #203d34 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(24, 49, 41, 0.18);
}
.pay-eyebrow.data-v-32f2f1fc {
  font-size: 22rpx;
  line-height: 30rpx;
  color: rgba(244, 162, 89, 0.96);
  font-weight: 600;
}
.pay-title.data-v-32f2f1fc {
  display: block;
  margin-top: 14rpx;
  font-size: 40rpx;
  line-height: 52rpx;
  font-weight: 700;
}
.pay-desc.data-v-32f2f1fc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 38rpx;
  color: rgba(255, 255, 255, 0.76);
}
