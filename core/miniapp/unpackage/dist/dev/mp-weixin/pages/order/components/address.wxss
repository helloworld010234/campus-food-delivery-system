.address_card.data-v-04873fd5 {
  margin-bottom: 22rpx;
  padding: 8rpx 28rpx;
  border-radius: 32rpx;
  background: #fbfaf7;
  box-shadow: 0 20rpx 50rpx rgba(36, 54, 46, 0.08);
}
.card_row.data-v-04873fd5 {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
